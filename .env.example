# =============================================================================
# SMARTOLT GATEWAY - Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets to version control.
# =============================================================================

# Application
NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_URL=http://localhost:3000
# Dominio público (lo usa Nginx en el host como server_name)
APP_DOMAIN=smartolt.yourdomain.com
LOG_LEVEL=info

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
API_KEY_SALT=your-api-key-salt-for-hashing-change-in-production

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMeInProduction!

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Local dev: leave as-is if using Homebrew postgres
# Docker prod: set POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB too
DATABASE_URL=postgresql://postgres:pwd@localhost:5432/smartolt?schema=public

POSTGRES_USER=smartolt
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=smartolt_db
# Puerto del host para acceso local a Postgres (solo 127.0.0.1, vía SSH tunnel)
POSTGRES_LOCAL_PORT=5433

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev (Homebrew Redis, no password): leave REDIS_PASSWORD empty
# Docker prod: set a strong password — it is required by docker-compose
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=smartolt:
REDIS_MAX_MEMORY=512mb

# ─── SmartOLT API ─────────────────────────────────────────────────────────────
SMARTOLT_BASE_URL=https://{subdomain}.smartolt.com/api
SMARTOLT_TIMEOUT=30000
SMARTOLT_RETRY_ATTEMPTS=3
SMARTOLT_RETRY_DELAY=1000
SMARTOLT_CIRCUIT_BREAKER_THRESHOLD=5
SMARTOLT_CIRCUIT_BREAKER_TIMEOUT=60000

# ─── Cache TTL (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_OLTS=600
CACHE_TTL_ONUS=300
CACHE_TTL_SIGNAL_LEVELS=900
CACHE_TTL_ONU_STATUS=300
CACHE_TTL_ONU_TYPES=86400
CACHE_TTL_DEFAULT=300

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ─── BullMQ ───────────────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=2000

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ─── Swagger ──────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_HOST=localhost:3000

# ─── Docker Compose (producción) ──────────────────────────────────────────────
# Puerto del host donde la API escucha (solo 127.0.0.1, Nginx hace proxy)
API_PORT_HOST=3001

IMAGE_TAG=latest
BUILD_DATE=
GIT_SHA=
VERSION=1.0.0

# Límites de recursos
POSTGRES_MEMORY_LIMIT=1g
REDIS_MEMORY_LIMIT=768m
REDIS_MAX_MEMORY=512mb
API_MEMORY_LIMIT=512m
API_CPU_LIMIT=1.0

# ─── Dev tools (docker compose --profile dev up) ──────────────────────────────
PGADMIN_EMAIL=admin@smartolt.local
PGADMIN_PASSWORD=change-me-dev-password
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=change-me-dev-password
