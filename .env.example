# =============================================================================
# SMARTOLT GATEWAY - Environment Variables
# =============================================================================

# Application
NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=info

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
API_KEY_SALT=your-api-key-salt-for-hashing

# Admin
ADMIN_EMAIL=admin@integracolombia.online
ADMIN_PASSWORD=ChangeMeInProduction!

# PostgreSQL
DATABASE_URL=postgresql://smartolt:smartolt_password@localhost:5432/smartolt_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=smartolt_redis_password
REDIS_DB=0
REDIS_KEY_PREFIX=smartolt:

# SmartOLT
SMARTOLT_BASE_URL=https://{subdomain}.smartolt.com/api
SMARTOLT_TIMEOUT=30000
SMARTOLT_RETRY_ATTEMPTS=3
SMARTOLT_RETRY_DELAY=1000
SMARTOLT_CIRCUIT_BREAKER_THRESHOLD=5
SMARTOLT_CIRCUIT_BREAKER_TIMEOUT=60000

# Cache TTL (seconds)
CACHE_TTL_OLTS=600
CACHE_TTL_ONUS=300
CACHE_TTL_SIGNAL_LEVELS=900
CACHE_TTL_ONU_STATUS=300
CACHE_TTL_ONU_TYPES=86400
CACHE_TTL_DEFAULT=300

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# BullMQ
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=2000

# CORS
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_HOST=localhost:3000
