# =============================================================================
# Nginx site config para SmartOLT Gateway
# =============================================================================
#
# Instalación en el servidor (Debian/Ubuntu):
#   1. Copiar este archivo a /etc/nginx/sites-available/smartolt.conf
#   2. Ajustar `server_name` y rutas de certificados
#   3. Activar:
#        sudo ln -s /etc/nginx/sites-available/smartolt.conf /etc/nginx/sites-enabled/
#        sudo nginx -t
#        sudo systemctl reload nginx
#   4. Generar certificado SSL (si no lo tienes):
#        sudo certbot --nginx -d smartolt.tu-dominio.com
# =============================================================================

# Rate limiting global por IP (10 req/seg, ráfaga de 20)
limit_req_zone $binary_remote_addr zone=smartolt_api:10m rate=10r/s;

# HTTP → HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name smartolt.tu-dominio.com;

    # Para que certbot pueda renovar el certificado
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS principal
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name smartolt.tu-dominio.com;

    # ── SSL / Let's Encrypt ─────────────────────────────────────────────────
    ssl_certificate     /etc/letsencrypt/live/smartolt.tu-dominio.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/smartolt.tu-dominio.com/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # OCSP stapling
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout 5s;

    # ── Security Headers ────────────────────────────────────────────────────
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    # ── Logs ────────────────────────────────────────────────────────────────
    access_log /var/log/nginx/smartolt.access.log;
    error_log  /var/log/nginx/smartolt.error.log warn;

    # ── Body size para POST grandes (opcional, ajusta si tu API lo necesita) ─
    client_max_body_size 10m;

    # ── Compresión ──────────────────────────────────────────────────────────
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/json
        application/javascript
        application/xml+rss
        application/atom+xml
        image/svg+xml;

    # ── Reverse proxy hacia la API ──────────────────────────────────────────
    location / {
        # Rate limit (ajustable; quita la línea si no lo quieres)
        limit_req zone=smartolt_api burst=20 nodelay;

        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;

        # Headers necesarios para que Fastify reciba el origen real
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        # Timeouts (ajustar según tu carga)
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;

        # Buffering
        proxy_buffering    on;
        proxy_buffer_size  16k;
        proxy_buffers      8 16k;

        # Soporte WebSocket por si lo necesitas en el futuro
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # ── Health check público (sin rate limit) ───────────────────────────────
    location = /live {
        proxy_pass http://127.0.0.1:3001/live;
        access_log off;
    }

    # ── Bloquear archivos sensibles ─────────────────────────────────────────
    location ~ /\.(env|git|ht) {
        deny all;
        return 404;
    }
}
